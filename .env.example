ENVIRONMENT=development
DATABASE_URL=sqlite:///./suicideprevention.db
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Resolved by app.ml.common.paths to the repository-level ml_models/ directory.
MODEL_ROOT=../ml_models
UPLOAD_ROOT=./uploaded_audio
REDIS_URL=redis://localhost:6379/0

# PostgreSQL example for production or staging:
# DATABASE_URL=postgresql+psycopg2://suicide_app:change-me@localhost:5432/suicide_prevention
